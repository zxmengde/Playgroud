{
  "version": 1,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"$root = git rev-parse --show-toplevel; & (Join-Path $root 'scripts/codex-hook-risk-check.ps1')\""
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"$root = git rev-parse --show-toplevel; & (Join-Path $root 'scripts/codex-hook-session-start.ps1')\""
      }
    ],
    "Stop": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"$root = git rev-parse --show-toplevel; & (Join-Path $root 'scripts/codex-hook-stop-check.ps1')\""
      }
    ]
  }
}
